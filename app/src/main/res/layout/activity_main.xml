<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="10dp"
    android:paddingTop="10dp"
    android:paddingEnd="10dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/mint_50"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/green_200"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="10dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/shareInputLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_share_text"
                    app:boxBackgroundColor="@color/mint_100"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxStrokeColor="@color/green_400"
                    app:boxStrokeErrorColor="@color/green_600"
                    app:hintTextColor="@color/ink_500">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/shareEditText"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:gravity="top|start"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLines="4"
                        android:paddingTop="8dp"
                        android:textColor="@color/ink_900"
                        android:textColorHint="@color/ink_500"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/pasteButton"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:insetTop="8dp"
                        android:insetBottom="8dp"
                        android:text="@string/button_paste_link"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/green_600"
                        app:cornerRadius="14dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/clearButton"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_weight="1"
                        android:insetTop="8dp"
                        android:insetBottom="8dp"
                        android:text="@string/button_clear_link"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/green_600"
                        app:cornerRadius="14dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/extractButton"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:insetTop="10dp"
                    android:insetBottom="10dp"
                    android:text="@string/button_extract"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    app:backgroundTint="@color/green_700"
                    app:cornerRadius="16dp" />

                <ProgressBar
                    android:id="@+id/actionProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:indeterminate="true"
                    android:max="100"
                    android:progressBackgroundTint="@color/green_100"
                    android:progressTint="@color/green_700"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/statusTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/status_idle"
                    android:textColor="@color/ink_900"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detailTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:lineSpacingExtra="1dp"
                    android:maxLines="2"
                    android:text="@string/result_waiting_hint"
                    android:textColor="@color/ink_600"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/line_200"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:id="@+id/resultSummaryTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/ink_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/resultTabLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:minHeight="34dp"
                    app:tabIndicatorColor="@color/green_600"
                    app:tabIndicatorFullWidth="false"
                    app:tabPaddingBottom="2dp"
                    app:tabPaddingTop="2dp"
                    app:tabRippleColor="@color/green_100"
                    app:tabSelectedTextColor="@color/green_700"
                    app:tabTextColor="@color/ink_500" />

                <FrameLayout
                    android:id="@+id/previewSurfaceContainer"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_media_preview_surface"
                    android:padding="6dp">

                    <ImageView
                        android:id="@+id/previewImageView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/tab_image"
                        android:scaleType="fitCenter"
                        android:visibility="gone" />

                    <VideoView
                        android:id="@+id/previewVideoView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/previewPlaceholderTextView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:focusable="false"
                        android:gravity="center"
                        android:padding="20dp"
                        android:text="@string/placeholder_no_preview"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <ProgressBar
                        android:id="@+id/previewLoadingBar"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:indeterminate="true"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/titleContentTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_preview_surface"
                    android:lineSpacingExtra="2dp"
                    android:padding="14dp"
                    android:textColor="@color/ink_900"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/imageControlsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/previousImageButton"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:text="@string/label_prev_image"
                        android:textAllCaps="false"
                        android:textColor="@color/green_700"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/green_300" />

                    <TextView
                        android:id="@+id/imageIndicatorTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="@string/label_page_indicator_default"
                        android:textColor="@color/ink_500"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/nextImageButton"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:text="@string/label_next_image"
                        android:textAllCaps="false"
                        android:textColor="@color/green_700"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/green_300" />
                </LinearLayout>

                <TextView
                    android:id="@+id/resultHintTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ink_600"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyLinkButton"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:text="@string/label_copy_link"
                        android:textAllCaps="false"
                        android:textColor="@color/green_700"
                        app:cornerRadius="14dp"
                        app:strokeColor="@color/green_300" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/savePrimaryButton"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:text="@string/label_save_video"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/green_600"
                        app:cornerRadius="14dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/saveAllButton"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:layout_weight="1"
                        android:text="@string/label_save_all"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/green_700"
                        app:cornerRadius="14dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
